# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/toolshare"

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# ─── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"

# ─── Email ───────────────────────────────────────────────────────────────────
# Use either SendGrid or Resend
EMAIL_PROVIDER="sendgrid"          # "sendgrid" or "resend"
SENDGRID_API_KEY="SG.your-api-key"
RESEND_API_KEY="re_your-api-key"
EMAIL_FROM="noreply@toolshare.dk"
EMAIL_FROM_NAME="ToolShare"

# ─── File uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_BYTES=5242880         # 5 MB
